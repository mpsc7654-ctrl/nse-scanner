# NSE F&O Scanner — Production Environment Variables
# Copy to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=nse_scanner
POSTGRES_USER=nse
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── Redis ───────────────────────────────────────────────────────────────────
# No password needed for single-machine Redis; add requirepass for multi-host
REDIS_URL=redis://redis:6379/0

# ─── AI (optional — only used for market summaries) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXX

# ─── App ─────────────────────────────────────────────────────────────────────
DATA_FETCH_INTERVAL=60
DEBUG=false
DOMAIN=your-domain.com

# ─── Railway / Render auto-inject ─────────────────────────────────────────────
# DATABASE_URL and REDIS_URL are set automatically on Railway/Render
# They override the postgres/redis service URLs above
